{
  "id": "mmnap7zsnswzg4",
  "name": "Discord Bot for Copa City",
  "slides": [
    {
      "id": "mmnap7zs492xjk",
      "html": "<div class=\"slide\">\n  <div class=\"orb\" style=\"width:500px;height:500px;background:radial-gradient(circle,rgba(88,101,242,0.1),transparent 70%);top:-200px;right:-100px;\"></div>\n  <div class=\"corner c-tl\"></div><div class=\"corner c-br\"></div>\n  <div class=\"z\"><div class=\"label\">Case Study</div>\n    <h1 style=\"margin-bottom:14px;\">Copa City <br /><span class=\"accent\">Wishlist Party Bot</span></h1>\n    <p class=\"body-text\">Automating Steam wishlist verification for a gaming community of thousands.</p>\n  </div>\n  <div class=\"z\" style=\"flex:1;margin-top:28px;display:flex;gap:16px;\"></div>\n  <div class=\"z\" style=\"display:flex;gap:8px;flex-wrap:wrap;margin-top:24px;\">\n    \n  <span class=\"pill\">Discord.js</span><span class=\"pill\">Express</span><span class=\"pill\">Prisma</span><span class=\"pill\">Docker</span><span class=\"pill\">Steam API</span></div>\n  <div class=\"z\" style=\"flex: 1 1 0%; margin-top: 28px; display: flex; gap: 16px;\"><div class=\"ss\" style=\"flex: 1 1 0%; overflow: hidden;\"><img src=\"/api/admin/images?name=Screenshot_2026-03-12_at_13.29.52.png\" style=\"width:100%;height:100%;object-fit:cover;object-position:top;\" /></div></div><div class=\"sn\">01 / 05</div><div class=\"ub\">szamowski.dev</div>\n</div>"
    },
    {
      "id": "mmnd2oqi6t5d",
      "html": "<div class=\"slide\">\n  <div class=\"orb\" style=\"width:500px;height:500px;background:radial-gradient(circle,rgba(13,223,114,0.08),transparent 70%);top:50%;left:-5%;\"></div>\n  <div class=\"corner c-tl\"></div><div class=\"corner c-br\"></div>\n  <div class=\"z\"><div class=\"label\">The Challenge</div>\n    <h2>How do you verify<br /> thousands of <span class=\"accent\">wishlists?</span></h2>\n    <p class=\"body-text\" style=\"margin-top:16px;margin-bottom:36px;\">Copa City is launching on PC, PS5 and Xbox. The team needed a way to incentivize their Discord community to wishlist the game on Steam and verify it at scale. Manual checking was not an option.</p>\n  </div>\n  <div class=\"z\" style=\"flex:1;display:flex;flex-direction:column;gap:28px;\">\n    <div style=\"display:flex;gap:20px;align-items:flex-start;\">\n      <div class=\"glow-dot\" style=\"font-size: 37px !important;\"></div>\n      <div><div style=\"color:#ffffff;font-size:19px;font-weight:600;\">No link between Discord and Steam</div><div style=\"color:rgba(200,200,220,0.35);font-size:15px;margin-top:6px;line-height:1.6;\">Users live on Discord but wishlists live on Steam. There was no way to connect the two identities automatically.</div></div>\n    </div>\n    <div style=\"display:flex;gap:20px;align-items:flex-start;\">\n      <div class=\"glow-dot\" style=\"font-size: 37px !important;\"></div>\n      <div><div style=\"color:#ffffff;font-size:19px;font-weight:600;\">Steam API limitations</div><div style=\"color:rgba(200,200,220,0.35);font-size:15px;margin-top:6px;line-height:1.6;\">Wishlist data is only accessible for public profiles, and even then requires specific API calls and fallback strategies.</div></div>\n    </div>\n    <div style=\"display:flex;gap:20px;align-items:flex-start;\">\n      <div class=\"glow-dot\" style=\"font-size: 37px !important;\"></div>\n      <div><div style=\"color:#ffffff;font-size:19px;font-weight:600;\">Scale of the community</div><div style=\"color:rgba(200,200,220,0.35);font-size:15px;margin-top:6px;line-height:1.6;\">Hundreds of users submitting profiles across multiple days. Manually checking each one would take hours and introduce errors.</div></div>\n    </div>\n  </div>\n  <div class=\"z\" style=\"flex: 1 1 0%; margin-top: 28px; display: flex; gap: 16px;\"><div class=\"ss\" style=\"flex: 1 1 0%; overflow: hidden;\"><img src=\"/api/admin/images?name=Screenshot_2026-03-12_at_13.30.28.png\" style=\"width:100%;height:100%;object-fit:cover;object-position:top;\" /></div></div><div class=\"sn\">02 / 05</div><div class=\"ub\">szamowski.dev</div>\n</div>"
    },
    {
      "id": "mmnd4eagy1li",
      "html": "<div class=\"slide\">\n  <div class=\"orb\" style=\"width:500px;height:500px;background:radial-gradient(circle,rgba(13,223,114,0.1),transparent 70%);bottom:-200px;left:-100px;\"></div>\n  <div class=\"orb\" style=\"width:400px;height:400px;background:radial-gradient(circle,rgba(29,57,43,0.4),transparent 70%);top:-100px;right:-50px;\"></div>\n  <div class=\"corner c-tl\"></div><div class=\"corner c-br\"></div>\n  <div class=\"z\"><div class=\"label\" style=\"font-size: 12px;\">Tech Stack</div>\n    <h2 style=\"font-size: 44px;\">Built for<br /><span class=\"accent\"> reliability and scale</span></h2>\n  </div>\n  <div class=\"z\" style=\"flex:1;display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-top:36px;\">\n    <div class=\"mc\" style=\"display:flex;flex-direction:column;justify-content:center;\">\n      <div style=\"font-family: &quot;JetBrains Mono&quot;, monospace; color: rgb(13, 223, 114); font-weight: 700; font-size: 40px !important;\">Discord.js</div>\n      <div style=\"color: rgba(200, 200, 220, 0.4); margin-top: 12px; line-height: 1.5; font-size: 34px !important;\">Slash commands, embeds, role management, DMs</div>\n    </div>\n    <div class=\"mc\" style=\"display:flex;flex-direction:column;justify-content:center;\">\n      <div style=\"font-family: &quot;JetBrains Mono&quot;, monospace; color: rgb(13, 223, 114); font-weight: 700; font-size: 40px !important;\">Next.js</div>\n      <div style=\"color: rgba(200, 200, 220, 0.4); margin-top: 12px; line-height: 1.5; font-size: 34px !important;\">Web server with Steam OAuth login flow</div>\n    </div>\n    <div class=\"mc\" style=\"display:flex;flex-direction:column;justify-content:center;\">\n      <div style=\"font-family: &quot;JetBrains Mono&quot;, monospace; color: rgb(13, 223, 114); font-weight: 700; font-size: 40px !important;\">Prisma + PostgreSQL</div>\n      <div style=\"color: rgba(200, 200, 220, 0.4); margin-top: 12px; line-height: 1.5; font-size: 34px !important;\">Submissions, audit log, config, analytics</div>\n    </div>\n    <div class=\"mc\" style=\"display:flex;flex-direction:column;justify-content:center;\">\n      <div style=\"font-family: &quot;JetBrains Mono&quot;, monospace; color: rgb(13, 223, 114); font-weight: 700; font-size: 40px !important;\">Steam Web API</div>\n      <div style=\"color: rgba(200, 200, 220, 0.4); margin-top: 12px; line-height: 1.5; font-size: 34px !important;\">Profile validation and wishlist verification</div>\n    </div>\n  </div>\n  <div class=\"sn\">03 / 05</div><div class=\"ub\">szamowski.dev</div>\n</div>"
    },
    {
      "id": "mmnd7pzg5bux",
      "html": "<div class=\"slide\">\n  <div class=\"orb\" style=\"width:600px;height:600px;background:radial-gradient(circle,rgba(13,223,114,0.12),transparent 70%);top:30%;left:50%;transform:translateX(-50%);\"></div>\n  <div class=\"corner c-tl\"></div><div class=\"corner c-br\"></div>\n  <div class=\"z\"><div class=\"label\">Results</div>\n    <h2>193 users <br />verified<span class=\"accent\"> in 12 days</span></h2>\n  </div>\n  <div class=\"z\" style=\"flex:1;display:flex;flex-direction:column;gap:20px;margin-top:40px;\">\n    <div class=\"mc\" style=\"display:flex;align-items:center;gap:32px;\">\n      <div class=\"stat-number\" style=\"font-size: 70px;\">193</div>\n      <div><div style=\"color:#ffffff;font-size:20px;font-weight:600;\">Unique participants submitted their Steam profiles through Discord commands or Web OAuth</div><div class=\"stat-label\" style=\"font-size: 26px;\"></div></div>\n    </div>\n    <div class=\"mc\" style=\"display:flex;align-items:center;gap:32px;\">\n      <div class=\"stat-number\" style=\"font-size: 70px;\">129</div>\n      <div><div style=\"color:#ffffff;font-size:20px;font-weight:600;\">Wishlists verified and confirmed (67% conversion from submission to verified status)</div><div class=\"stat-label\" style=\"font-size: 26px;\"></div></div>\n    </div>\n    <div class=\"mc\" style=\"display:flex;align-items:center;gap:32px;\">\n      <div class=\"stat-number\" style=\"font-size: 70px;\">119</div>\n      <div><div style=\"color:#ffffff;font-size:20px;font-weight:600;\">Completed entirely through Web OAuth flow with zero manual intervention from the team</div><div class=\"stat-label\" style=\"font-size: 26px;\"></div></div>\n    </div>\n  </div>\n  <div class=\"z\" style=\"flex: 1 1 0%; margin-top: 28px; display: flex; gap: 16px;\"><div class=\"ss\" style=\"flex: 1 1 0%; overflow: hidden;\"><img src=\"/api/admin/images?name=0-swirl-buck.jpg\" style=\"width:100%;height:100%;object-fit:cover;object-position:top;\" /></div></div><div class=\"sn\">04 / 05</div><div class=\"ub\">szamowski.dev</div>\n</div>"
    },
    {
      "id": "mmnd7j7498yd",
      "html": "<div class=\"slide\" style=\"align-items:center;justify-content:center;\">\n  <div class=\"orb\" style=\"width:700px;height:700px;background:radial-gradient(circle,rgba(13,223,114,0.1),transparent 70%);top:50%;left:50%;transform:translate(-50%,-50%);\"></div>\n  <div class=\"orb\" style=\"width:400px;height:400px;background:radial-gradient(circle,rgba(29,57,43,0.4),transparent 70%);bottom:-10%;left:-5%;\"></div>\n  <div class=\"corner c-tl\"></div><div class=\"corner c-br\"></div>\n  <div class=\"z\" style=\"display:flex;flex-direction:column;align-items:center;text-align:center;gap:36px;\">\n    <div class=\"label\" style=\"font-size:13px;\">Want to see more?</div>\n    <div class=\"logo-badge\"><div class=\"badge-left\">szamowski</div><div class=\"badge-right\">.dev</div></div>\n    <h2 style=\"font-size:52px;margin-bottom:0;\">Strategy consulting<br><span class=\"accent\">meets fullstack<br>development.</span></h2>\n    <div class=\"divider\"></div>\n    <p class=\"body-text\" style=\"max-width:650px;font-size:20px;\">Full case studies, tech deep-dives,<br>and project breakdowns on my website.</p>\n    <div style=\"display:flex;gap:10px;flex-wrap:wrap;justify-content:center;\">\n      <span class=\"pill\">Web Development</span><span class=\"pill\">Automation</span><span class=\"pill\">Marketing</span>\n    </div>\n    <div style=\"font-family:'JetBrains Mono',monospace;font-size:22px;color:#0ddf72;letter-spacing:0.1em;\">szamowski.dev/case-studies</div>\n  </div>\n  <div class=\"sn\">05 / 05</div><div class=\"ub\">szamowski.dev</div>\n</div>"
    }
